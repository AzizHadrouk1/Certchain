# Hedera Network Configuration
HEDERA_NETWORK=testnet

# Hedera Account Credentials (Testnet)
# Get from https://portal.hedera.com
HEDERA_ACCOUNT_ID=0.0.XXXXXXX
HEDERA_PRIVATE_KEY=302e020100300506032b6570...

# HCS Topic ID (created once, reused for all certificate submissions)
# Leave blank on first run — the app will create it automatically
HEDERA_TOPIC_ID=

# Server
PORT=3000
FRONTEND_URL=http://localhost:4200
